ShapeNBV/report/figures/make_fig3_tile_prototype.py
ShapeNBV/report/figures/make_fig4_caption_counterfactual.py

# === Un-ignore overrides (must come AFTER matching ignore rules) ===
# NeurIPS LaTeX template (overrides top-level *.sty and ShapeNBV/**/*.pdf)
!ShapeNBV/report/*.sty
!ShapeNBV/report/*.pdf
!ShapeNBV/report/figures/*.png
!ShapeNBV/report/figures/*.pdf
# Asset PNGs used by figures (overrides ShapeNBV/**/*.png in nested dirs)
!ShapeNBV/report/figures/assets/*.png
!ShapeNBV/report/figures/assets/attr_icons/*.png
!ShapeNBV/report/figures/assets/vlm_icons/*.png
!ShapeNBV/report/figures/assets/fig4_hard_caption_probe_grid/
!ShapeNBV/report/figures/assets/fig4_hard_caption_probe_grid/caption_contrast_grid_rollouts.json
!ShapeNBV/report/figures/assets/fig5_coverage_curves/
!ShapeNBV/report/figures/assets/fig5_coverage_curves/coverage_curves.csv
!ShapeNBV/report/figures/assets/fig5_coverage_curves/coverage_curves_meta.json
!ShapeNBV/report/figures/assets/figA1_training_dynamics/
!ShapeNBV/report/figures/assets/figA1_training_dynamics/training_dynamics.csv
!ShapeNBV/report/figures/assets/figA1_training_dynamics/training_dynamics_meta.json

# Re-ignore superseded intermediate composites (must come AFTER un-ignores)
ShapeNBV/report/figures/assets/chair_contact_sheet.png
ShapeNBV/report/figures/assets/chair_contact_sheet_clean.png
ShapeNBV/report/figures/fig4_caption_counterfactual*
