# Copy to .env locally if desired. Do not commit real credentials.

# Licensed ShapeNetCore.v2 root. This directory should contain synset folders
# such as 03001627, 04256520, and 04379243.
SHAPENET_ROOT=/path/to/ShapeNetCore.v2

# Preprocessed object grids with optional caption embeddings.
PREPROC_DIR=/path/to/geoscout_artifacts/preproc/train600_attr_v2
OOD_PREPROC_DIR=/path/to/geoscout_artifacts/preproc/ood300_attr_v2

# Caption text and sentence-transformer embedding payloads.
CAPTION_JSONL=/path/to/geoscout_artifacts/captions/train600_revised.jsonl
CAPTION_EMB_PATH=/path/to/geoscout_artifacts/captions/train600_minilm_l6.pt

# Trained PPO checkpoints. Keep these outside git.
GEOSCOUT_CKPT=/path/to/geoscout_artifacts/ckpts/geoscout_discrete_revised.zip
GEOSCOUT_RAW_CAP_CKPT=/path/to/geoscout_artifacts/ckpts/geoscout_discrete_raw_caption.zip
GEOSCOUT_NOCAP_CKPT=/path/to/geoscout_artifacts/ckpts/geoscout_discrete_nocap.zip

# Optional logging.
WANDB_PROJECT=shapenbv
WANDB_ENTITY=
WANDB_MODE=disabled

